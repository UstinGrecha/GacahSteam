# Auth.js / next-auth
# Сгенерировать секрет: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# База пользователей (Prisma). Локально SQLite:
DATABASE_URL="file:./dev.db"
# При DATABASE_URL залогиненные игроки: прогресс на сервере (паки/монеты/переработка),
# сутки и почасовой банк считаются по UTC.
# Production: postgres://user:pass@host:5432/dbname

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect: https://ваш-домен/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
